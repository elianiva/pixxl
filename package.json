{
  "name": "pixxl",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently --names 'frontend,backend' 'pnpm --filter frontend dev' 'pnpm --filter backend dev'",
    "dev:frontend": "pnpm --filter frontend dev",
    "dev:backend": "pnpm --filter backend dev",
    "build": "pnpm --filter frontend build",
    "check": "pnpm -r check",
    "check:frontend": "pnpm --filter frontend check"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "vite-plus": "latest"
  },
  "packageManager": "pnpm@10.32.1"
}
