{
  "name": "pixxl",
  "version": "0.0.1",
  "description": "AI-powered local-first code workspace",
  "type": "module",
  "bin": {
    "pixxl": "./bin/pixxl"
  },
  "files": [
    "bin/pixxl",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "concurrently --names 'frontend,backend' 'pnpm --filter frontend dev' 'pnpm --filter backend dev'",
    "dev:frontend": "pnpm --filter frontend dev",
    "dev:backend": "pnpm --filter backend dev",
    "start": "./bin/pixxl",
    "build": "pnpm run build:frontend && pnpm run build:binary",
    "build:frontend": "pnpm --filter frontend build",
    "build:binary": "bash scripts/build.sh",
    "check": "pnpm -r check",
    "check:frontend": "pnpm --filter frontend check",
    "prepublishOnly": "pnpm run build"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "vite-plus": "latest"
  },
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "bun": ">=1.2.0"
  }
}
