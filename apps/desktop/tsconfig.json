{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "baseUrl": ".",
    "esModuleInterop": true,
    "types": ["node"],
    "paths": {
      "@/*": ["../backend/src/*"],
      "@pixxl/shared": ["../../packages/shared/src"],
      "@pixxl/shared/*": ["../../packages/shared/src/*"]
    }
  },
  "include": ["src/**/*", "../backend/src/**/*"]
}
